{
  "name": "swym",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "dev:device": "turbo dev --filter=@swym/device-ui",
    "build:device": "turbo build --filter=@swym/device-ui",
    "dev:app": "turbo dev --filter=@swym/app",
    "build:app": "turbo build --filter=@swym/app",
    "start": "turbo dev"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
